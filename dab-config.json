{
  "$schema": "https://github.com/Azure/data-api-builder/releases/download/v1.7.90/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('MSSQL_CONNECTION_STRING')",
    "options": {
      "set-session-context": false
    }
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/api",
      "request-body-strict": true
    },
    "graphql": {
      "enabled": true,
      "path": "/graphql",
      "allow-introspection": true
    },
    "mcp": {
      "enabled": true,
      "path": "/mcp"
    },
    "host": {
      "cors": {
        "origins": [],
        "allow-credentials": false
      },
      "authentication": {
        "provider": "AppService"
      },
      "mode": "development"
    }
  },
  "entities": {
    "Matches": {
      "description": "Soccer match schedule data",
      "source": {
        "object": "dbo.Matches",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Matches",
          "plural": "Matches"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "Teams": {
      "description": "Teams with logos and division membership",
      "source": {
        "object": "dbo.Teams",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Teams",
          "plural": "Teams"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "Venues": {
      "description": "Match venues/locations",
      "source": {
        "object": "dbo.Venues",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Venues",
          "plural": "Venues"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "Leagues": {
      "description": "League organizations (MLS Next, etc)",
      "source": {
        "object": "dbo.Leagues",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Leagues",
          "plural": "Leagues"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "Divisions": {
      "description": "Divisions within leagues",
      "source": {
        "object": "dbo.Divisions",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Divisions",
          "plural": "Divisions"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "Regions": {
      "description": "Geographic regions",
      "source": {
        "object": "dbo.Regions",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Regions",
          "plural": "Regions"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "Competitions": {
      "description": "Competition types",
      "source": {
        "object": "dbo.Competitions",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Competitions",
          "plural": "Competitions"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "AgeGroups": {
      "description": "Age group classifications (U13-U18)",
      "source": {
        "object": "dbo.AgeGroups",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "AgeGroups",
          "plural": "AgeGroups"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "RawIngestionLogs": {
      "description": "Ingestion run logs",
      "source": {
        "object": "dbo.RawIngestionLogs",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "RawIngestionLogs",
          "plural": "RawIngestionLogs"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    }
  }
}